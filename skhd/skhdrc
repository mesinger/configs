ctrl - j : yabai -m window --focus south
ctrl - k : yabai -m window --focus north
ctrl - h : yabai -m window --focus west
ctrl - l : yabai -m window --focus east

ctrl + shift - j : yabai -m window --swap south
ctrl + shift - k : yabai -m window --swap north
ctrl + shift - h : yabai -m window --swap west
ctrl + shift - l : yabai -m window --swap east
ctrl + shift - o : yabai -m space --rotate 270

ctrl + shift - 1 : yabai -m window --space 1
ctrl + shift - 2 : yabai -m window --space 2
ctrl + shift - 3 : yabai -m window --space 3
ctrl + shift - 4 : yabai -m window --space 4
ctrl + shift - 5 : yabai -m window --space 5
ctrl + shift - 6 : yabai -m window --space 6

shift + lalt - up : yabai -m window --display 2
shift + lalt - down : yabai -m window --display 1
shift - left : yabai -m window --swap west
shift - right : yabai -m window --swap east

ctrl + shift - r : yabai -m space --balance

# cmd - return : open /Applications/iTerm.app
# cmd + alt + ctrl - f : open /Applications/Firefox.app

